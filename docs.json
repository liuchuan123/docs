{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "prism",
  "name": "PayMatrix",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "modeToggle": true,
  "openapi": {
    "merchant": {
      "source": "/openapi.yaml",
      "title": "PayMatrix Merchant API"
    }
  },
  "api": {
    "playground": {
      "mode": "show"
    }
  },
  "colors": {
    "primary": "#0052FF",
    "light": "#F5F8FF",
    "dark": "#0A0D14",
    "ultraLight": "#F0F4FF",
    "ultraDark": "#06080D",
    "background": {
      "light": "#FFFFFF",
      "dark": "#0A0D14"
    }
  },
  "topbar": {
    "style": "gradient",
    "gradient": {
      "from": "#0052FF",
      "to": "#6C47FF"
    }
  },
  "anchors": [
    {
      "name": "商户门户",
      "icon": "house",
      "url": "https://merchant.paymatrixpay.com"
    },
    {
      "name": "支持",
      "icon": "question",
      "url": "mailto:support@paymatrixpay.com"
    }
  ],
  "navbar": {
    "primary": {
      "type": "button",
      "label": "进入商户门户",
      "href": "https://merchant.paymatrixpay.com"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "帮助文档",
        "groups": [
          {
            "group": "概览",
            "pages": [
              "index",
              "getting-started/quickstart"
            ]
          },
          {
            "group": "入驻指南",
            "pages": [
              "onboarding/overview",
              "onboarding/registration",
              "onboarding/verification",
              "onboarding/account-setup"
            ]
          },
          {
            "group": "商户门户",
            "pages": [
              "portal/dashboard",
              "portal/orders",
              "portal/settlements",
              "portal/developer-settings",
              "portal/account"
            ]
          },
          {
            "group": "核心概念",
            "pages": [
              "concepts/payment-flow",
              "concepts/order-lifecycle",
              "concepts/settlement",
              "concepts/ledger"
            ]
          }
        ]
      },
      {
        "tab": "商户接入",
        "groups": [
          {
            "group": "接入准备",
            "pages": [
              "integration/overview",
              "integration/authentication",
              "integration/ip-whitelist",
              "integration/sandbox"
            ]
          },
          {
            "group": "支付 API",
            "pages": [
              "api/payment/create",
              "api/payment/query",
              "api/payment/refund",
              "api/payment/query-refund"
            ]
          },
          {
            "group": "通知回调",
            "pages": [
              "api/webhook/overview",
              "api/webhook/events",
              "api/webhook/signature"
            ]
          },
          {
            "group": "收银台 API",
            "pages": [
              "api/checkout/payment-methods",
              "api/checkout/init",
              "api/checkout/submit"
            ]
          },
          {
            "group": "收银台集成",
            "pages": [
              "checkout/overview",
              "checkout/hosted",
              "checkout/custom"
            ]
          },
          {
            "group": "附录",
            "pages": [
              "appendix/errors",
              "appendix/currency"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://www.paymatrixpay.com"
    }
  }
}
